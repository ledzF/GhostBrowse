{
  "manifest_version": 3,
  "name": "Website Reputation Guardian",
  "version": "1.0",
  "description": "Advanced website safety analysis with real-time reputation scoring",
  "permissions": ["tabs", "activeTab", "storage", "webNavigation", "alarms"],
  "host_permissions": [
    "<all_urls>",
    "https://www.virustotal.com/*",
    "https://archive.org/*",
    "https://safebrowsing.googleapis.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "Check Website Safety"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  },
  "commands": {
    "_execute_action": {
        "suggested_key": {
            "default": "Ctrl+Shift+S",
            "mac": "Command+Shift+S"
        },
        "description": "Check current website"
    },
    "quick-scan": {
        "suggested_key": {
            "default": "Ctrl+Shift+L",
            "mac": "Command+Shift+L"
        },
        "description": "Quick scan and show notification"
    }
  }
}